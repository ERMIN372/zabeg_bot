# Токен бота от @BotFather (обязательно)
BOT_TOKEN=1234567890:AAAA...

# Прокси до Telegram — нужен, если прямой доступ к api.telegram.org с хоста
# заблокирован/троттлится (DPI). Оставьте пустым, если Telegram доступен напрямую.
# Форматы: socks5://user:pass@host:1080 | socks5://host:1080 | http://host:3128
TELEGRAM_PROXY=

# Telegram user_id администраторов через запятую (узнать: @userinfobot)
ADMIN_IDS=123456789,987654321

# ID группы поддержки (добавьте бота в группу; ID вида -100xxxxxxxxxx)
SUPPORT_CHAT_ID=-1001234567890

# Ссылка на полный текст политики конфиденциальности (страница или PDF)
PRIVACY_POLICY_URL=https://example.com/privacy.pdf

# Версия текста согласия на ПДн: поднимайте при изменении политики
CONSENT_VERSION=1

# Раздел «Фото и видео»: single_link — одна ссылка на архив,
# per_event — список мероприятий с альбомами (поле «Ссылка на альбом» в админке)
PHOTO_MODE=single_link
PHOTOS_ARCHIVE_URL=https://disk.yandex.ru/d/xxxx

# Сколько часов даётся на подтверждение места из листа ожидания
WAITLIST_CONFIRM_HOURS=2

# Период тика планировщика в секундах
SCHEDULER_TICK_SECONDS=30

# Часовой пояс по умолчанию для новых мероприятий
DEFAULT_TIMEZONE=Europe/Moscow

# --- Mini app (веб-админка) -------------------------------------------------
# Домен для панели. Нужен для HTTPS (Telegram запускает Web App только по https).
# Бесплатно без покупки: зарегистрируйте поддомен на https://www.duckdns.org
# и направьте его на IP этого сервера. Пример: zabeg-admin.duckdns.org
# Либо без регистрации: <IP-сервера-с-дефисами>.sslip.io
# Оставьте пустым — mini app и кнопка в /admin просто не будут задействованы.
WEBAPP_DOMAIN=
# Полный https-URL панели (обычно https://<тот же WEBAPP_DOMAIN>).
# Бот покажет кнопку «Открыть панель» в /admin — её видят только админы.
WEBAPP_URL=

# БД. Для локального запуска без Docker — SQLite:
DATABASE_URL=sqlite+aiosqlite:///./zabeg.db
# В docker-compose DATABASE_URL подставляется автоматически (PostgreSQL),
# это значение игнорируется.

# Пароль PostgreSQL для docker-compose
POSTGRES_PASSWORD=change-me
